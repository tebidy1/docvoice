{
    "name": "SootNote - صوت نوت",
    "version": "1.0.0",
    "manifest_version": 3,
    "description": "AI-Powered Medical Documentation Workspace",
    "action": {
        "default_title": "SootNote",
        "default_icon": {
            "16": "icons/Icon-16.png",
            "48": "icons/Icon-48.png",
            "128": "icons/Icon-128.png"
        }
    },
    "side_panel": {
        "default_path": "index.html"
    },
    "permissions": [
        "sidePanel",
        "storage",
        "activeTab",
        "scripting"
    ],
    "host_permissions": [
        "<all_urls>"
    ],
    "background": {
        "service_worker": "background.js"
    },
    "content_scripts": [
        {
            "matches": [
                "<all_urls>"
            ],
            "js": [
                "content_script.js"
            ],
            "run_at": "document_end"
        }
    ],
    "content_security_policy": {
        "extension_pages": "script-src 'self' 'wasm-unsafe-eval'; object-src 'self'; font-src 'self' data: https://fonts.gstatic.com; connect-src 'self' https://api.groq.com https://generativelanguage.googleapis.com https://docapi.sootnote.com https://fonts.gstatic.com;"
    },
    "web_accessible_resources": [
        {
            "resources": [
                "assets/*",
                "flutter.js",
                "main.dart.js",
                "manifest.json",

                "icons/*"
            ],
            "matches": [
                "<all_urls>"
            ]
        }
    ],
    "icons": {
        "16": "icons/Icon-16.png",
        "48": "icons/Icon-48.png",
        "128": "icons/Icon-128.png"
    }
}